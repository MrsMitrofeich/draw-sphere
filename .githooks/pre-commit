#!/usr/bin/env bash
# Bumps the patch component of module/module.json version on every commit.
# Runs automatically — no manual step needed.
set -euo pipefail

JSON="module/module.json"

if [[ ! -f "$JSON" ]]; then
  echo "pre-commit: $JSON not found, skipping version bump" >&2
  exit 0
fi

# Read current version
CURRENT=$(python3 -c "import json; print(json.load(open('$JSON'))['version'])")

# Increment patch  (1.2.3 → 1.2.4)
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
PATCH=$(( PATCH + 1 ))
NEXT="${MAJOR}.${MINOR}.${PATCH}"

# Write back — python preserves key order (3.7+) and matches original 2-space indent
python3 - "$JSON" "$NEXT" <<'EOF'
import json, sys
path, version = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
data["version"] = version
with open(path, "w") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write("\n")
EOF

git add "$JSON"
echo "draw-sphere: version $CURRENT → $NEXT"
